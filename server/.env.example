# ===== JobScout 后端配置模板（示例，不含真实密钥）=====
# 复制本文件为同目录 .env 后填入你自己的值：cp .env.example .env
# ⚠️ 切勿把真实密钥提交进 git；.env 已被 .gitignore 忽略。

# 阿里云百炼（通义千问）API Key —— 必填，缺失时相关接口会明确报错
# 获取步骤：登录 https://bailian.console.aliyun.com/ -> API-KEY -> 创建
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE

# OpenAI 兼容端点（一般无需修改）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称，可切换 qwen-max / qwen-turbo / qwen3.5-plus-2026-04-20 等
LLM_MODEL=qwen3.5-plus-2026-04-20
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.2

# 数据库（默认 SQLite 本地文件）
DATABASE_URL=sqlite:///./internscout.db

# 允许跨域来源，多个用逗号分隔，* 表示全部
CORS_ORIGINS=*

# ── 百度 OCR（图片导入 JD 文字识别）─────────────────────────
# 获取步骤：登录 https://console.bce.baidu.com/qianjin/aim/create → 创建应用 → 读取 API Key / Secret Key
# 免费额度：通用高精度版 50 次/天；基础版 1000 次/天
BAIDU_OCR_APP_ID=YOUR_BAIDU_APP_ID_HERE
BAIDU_OCR_API_KEY=YOUR_BAIDU_OCR_API_KEY_HERE
BAIDU_OCR_SECRET_KEY=YOUR_BAIDU_OCR_SECRET_KEY_HERE

# ── OCR 服务商选择 ──────────────────────────────────────────
# baidu（默认）/ tencent。图片导入会走对应厂商
OCR_PROVIDER=baidu

# ── 腾讯云 OCR（备选，OCR_PROVIDER=tencent 时启用）──────────
# 获取步骤：登录 https://console.cloud.tencent.com/cam/capi → 新建密钥 → 读取 SecretId / SecretKey
# 免费额度：通用文字识别 1000 次/月
TENCENT_OCR_SECRET_ID=YOUR_TENCENT_SECRET_ID_HERE
TENCENT_OCR_SECRET_KEY=YOUR_TENCENT_SECRET_KEY_HERE
