# =========================
# JobScout 后端环境变量示例
# =========================

# 复制为 .env 后填写真实值

# -------- 全局默认 LLM（向后兼容）--------
# 当某个档位没有单独配置时，会回退到这里
LLM_PROVIDER=dashscope
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=YOUR_GLOBAL_API_KEY
LLM_MODEL=qwen-plus
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.2

# 向后兼容旧字段：如果你还在用旧配置，也仍然可用
DASHSCOPE_API_KEY=

# -------- 快速档：Resume / Job / Match(quick) --------
LLM_FAST_PROVIDER=
LLM_FAST_BASE_URL=
LLM_FAST_API_KEY=
LLM_FAST_MODEL=qwen3.5-flash-2026-02-23
LLM_FAST_ENABLE_THINKING=false

# -------- 推理档：Match(deep) --------
LLM_REASONING_PROVIDER=
LLM_REASONING_BASE_URL=
LLM_REASONING_API_KEY=
LLM_REASONING_MODEL=qwen3.7-max-2026-06-08
LLM_REASONING_ENABLE_THINKING=true

# -------- 报告档：Report Agent --------
LLM_REPORT_PROVIDER=
LLM_REPORT_BASE_URL=
LLM_REPORT_API_KEY=
LLM_REPORT_MODEL=qwen3.5-plus-2026-04-20
LLM_REPORT_ENABLE_THINKING=false

# -------- 视觉档：预留 --------
LLM_VISION_PROVIDER=
LLM_VISION_BASE_URL=
LLM_VISION_API_KEY=
LLM_VISION_MODEL=

# -------- OCR LLM 档：预留给大模型 OCR --------
LLM_OCR_PROVIDER=
LLM_OCR_BASE_URL=
LLM_OCR_API_KEY=
LLM_OCR_MODEL=

# -------- 兜底档：主模型失败后的二次重试 --------
LLM_FALLBACK_PROVIDER=
LLM_FALLBACK_BASE_URL=
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=

# -------- 数据库 / 跨域 --------
DATABASE_URL=sqlite:///./internscout.db
CORS_ORIGINS=*

# -------- 并发 --------
LLM_CONCURRENCY=3
JOB_AGENT_CONCURRENCY=6
MATCH_AGENT_CONCURRENCY=4
REPORT_AGENT_CONCURRENCY=6

# -------- 业务策略 --------
FULL_MODE_LIMIT=0
REPORT_AUTO_POLICY=top_k
REPORT_AUTO_TOP_K=5
REPORT_HISTORY_LIMIT=100
MATCH_TWO_TIER=true
DEEP_RESEARCH_ENABLED=false
DEEP_RESEARCH_STRATEGY=auto
DEEP_RESEARCH_MAX_ITEMS=6

# -------- 百度 OCR --------
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# -------- 腾讯 OCR --------
OCR_PROVIDER=tencent
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=
