
# =========================
# 全局默认（兜底）
# =========================
LLM_PROVIDER=dashscope
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
LLM_API_KEY=
LLM_MODEL=qwen3.5-plus-2026-04-20
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.2


# =========================
# FAST：Resume / Job / Match quick
# 走千问qwen3.5-flash-2026-02-23
# =========================
LLM_FAST_PROVIDER=dashscope
LLM_FAST_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FAST_API_KEY=
LLM_FAST_MODEL=qwen3.5-flash-2026-02-23

# =========================
# REASONING：Match deep
# 走千问qwen3.7-max-2026-06-08
# =========================
LLM_REASONING_PROVIDER=dashscope
LLM_REASONING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_REASONING_API_KEY=
LLM_REASONING_MODEL=qwen3.7-max-2026-06-08
LLM_REASONING_ENABLE_THINKING=true

# =========================
# VISION：低质量图片的多模态兜底
# 留空时继承全局 LLM 配置
# =========================
LLM_VISION_PROVIDER=dashscope
LLM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_VISION_API_KEY=
LLM_VISION_MODEL=qwen3.5-plus-2026-04-20

# =========================
# REPORT：深度报告
# 走deepseek-v4-pro
# =========================
LLM_REPORT_PROVIDER=deepseek
LLM_REPORT_BASE_URL=https://api.deepseek.com/
LLM_REPORT_API_KEY=
LLM_REPORT_MODEL=deepseek-v4-pro
LLM_REPORT_ENABLE_THINKING=true

# =========================
# 可选：fallback
# 不想启用就留空
# =========================
LLM_FALLBACK_PROVIDER=dashscope
LLM_FALLBACK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_FALLBACK_API_KEY=
LLM_FALLBACK_MODEL=qwen3.7-max

# =========================
# 业务策略
# =========================
MATCH_TWO_TIER=true
FULL_MODE_LIMIT=0
REPORT_AUTO_POLICY=top_k
REPORT_AUTO_TOP_K=5
REPORT_HISTORY_LIMIT=100

# 深度分析、深度报告固定强制尝试联网；失败时由对应模型基于已有材料继续生成。
# 这里只限制单个岗位最多生成多少条联网查询。
DEEP_RESEARCH_MAX_ITEMS=6

# =========================
# 并发
# =========================
LLM_CONCURRENCY=3
JOB_AGENT_CONCURRENCY=6
MATCH_AGENT_CONCURRENCY=4
REPORT_AGENT_CONCURRENCY=6

# =========================
# 数据库 / 跨域
# =========================
DATABASE_URL=sqlite:///./internscout.db
CORS_ORIGINS=*

# ── OCR 服务商选择 ───────────────────────────────────────
# tencent（默认，免费档 10 QPS）/ baidu（~2 QPS）。图片导入会走对应厂商
OCR_PROVIDER=tencent

# ── 百度 OCR（图片导入 JD 文字识别）─────────────────────────
# 获取步骤：登录 https://console.bce.baidu.com/qianjin/aim/create → 创建应用 → 读取 API Key / Secret Key
# 免费额度：通用高精度版 50 次/天；基础版 1000 次/天
BAIDU_OCR_APP_ID=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
# ── 腾讯云 OCR（备选，OCR_PROVIDER=tencent 时启用）──────────
# 获取步骤：登录 https://console.cloud.tencent.com/cam/capi → 新建密钥 → 读取 SecretId / SecretKey
# 免费额度：通用文字识别 1000 次/月
TENCENT_OCR_SECRET_ID=
TENCENT_OCR_SECRET_KEY=

# OCR 并发、速率与视觉兜底上界
TENCENT_OCR_CONCURRENCY=10
TENCENT_OCR_RATE_PER_SEC=10
BAIDU_OCR_CONCURRENCY=3
BAIDU_OCR_RATE_PER_SEC=2
VISION_OCR_CONCURRENCY=2
