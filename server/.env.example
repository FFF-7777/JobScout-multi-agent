# ===== JobScout 后端配置模板（示例，不含真实密钥）=====
# 复制本文件为同目录 .env 后填入你自己的值：cp .env.example .env
# ⚠️ 切勿把真实密钥提交进 git；.env 已被 .gitignore 忽略。

# 阿里云百炼（通义千问）API Key —— 必填，缺失时相关接口会明确报错
# 获取步骤：登录 https://bailian.console.aliyun.com/ -> API-KEY -> 创建
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE

# OpenAI 兼容端点（一般无需修改）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 默认模型（档位未单独配置时的回退值）；可切 qwen-max / qwen-turbo / qwen3.5-plus-2026-04-20 等
LLM_MODEL=qwen3.5-plus-2026-04-20
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.2

# ── 模型档位：按任务难度分配，而非按 Agent 绑定厂商 ──
# 设计：同一主厂商（dashscope）支撑多个 Agent。
# ⚠️ 留空则回退到下方 LLM_MODEL —— 即所有档位 / Agent 统一使用 LLM_MODEL 指定的模型，分档策略不生效。
#    当前 LLM_MODEL=qwen3.5-plus-2026-04-20，因此全链路（Resume/Job/Match/Report）皆用该模型，
#    符合「先统一、落地再细分」的过渡期策略；代码通路已备好，无需改代码即可切换。
#    落地启用分档时，在此填写具体模型名。填了即自动分流，未填继续回退 LLM_MODEL。
#
# ── 模型分配关系 ──
#   LLM_FAST_MODEL         → Resume / Job Agent  + Match(quick)     → 关闭思考
#   LLM_REASONING_MODEL    → Match(deep) 深度复核                   → 开启思考
#   LLM_REPORT_MODEL       → Report Agent 深度报告生成              → 关闭思考
#   LLM_OCR_MODEL          → OCR 截图文字识别                       → 不支持思考
#
# ── 推荐配置 ──
#   LLM_FAST_MODEL=qwen3.5-plus-2026-04-20
#   LLM_REASONING_MODEL=qwen3.7-max-2026-06-08
#   LLM_REPORT_MODEL=qwen3.7-max-2026-06-08
#   LLM_OCR_MODEL=qwen3.5-ocr
LLM_FAST_MODEL=
LLM_REASONING_MODEL=
LLM_REPORT_MODEL=
LLM_OCR_MODEL=
LLM_VISION_MODEL=
# 故障切换：主模型持续失败时，用下面的模型再试一次（可选；跨厂商兜底需自备第二厂商 Key）
LLM_FALLBACK_MODEL=

# ── 思考模式开关 ──
# reasoning 档（Match deep）建议开启，提升深度匹配准确率。
# report 档与 fast 档应关闭——思考模式与 response_format 不兼容，
# 开启后模型可能不严格输出 JSON，导致解析失败。
LLM_FAST_ENABLE_THINKING=false
LLM_REASONING_ENABLE_THINKING=true
LLM_REPORT_ENABLE_THINKING=false

# 数据库（默认 SQLite 本地文件）
DATABASE_URL=sqlite:///./internscout.db

# 允许跨域来源，多个用逗号分隔，* 表示全部
CORS_ORIGINS=*

# ── 百度 OCR（图片导入 JD 文字识别）─────────────────────────
# 获取步骤：登录 https://console.bce.baidu.com/qianjin/aim/create → 创建应用 → 读取 API Key / Secret Key
# 免费额度：通用高精度版 50 次/天；基础版 1000 次/天
BAIDU_OCR_APP_ID=YOUR_BAIDU_APP_ID_HERE
BAIDU_OCR_API_KEY=YOUR_BAIDU_OCR_API_KEY_HERE
BAIDU_OCR_SECRET_KEY=YOUR_BAIDU_OCR_SECRET_KEY_HERE

# ── OCR 服务商选择 ──────────────────────────────────────────
# tencent（默认，10 QPS）/ baidu（~2 QPS）。图片导入会走对应厂商
OCR_PROVIDER=tencent

# ── 腾讯云 OCR（备选，OCR_PROVIDER=tencent 时启用）──────────
# 获取步骤：登录 https://console.cloud.tencent.com/cam/capi → 新建密钥 → 读取 SecretId / SecretKey
# 免费额度：通用文字识别 1000 次/月
TENCENT_OCR_SECRET_ID=YOUR_TENCENT_SECRET_ID_HERE
TENCENT_OCR_SECRET_KEY=YOUR_TENCENT_SECRET_KEY_HERE
