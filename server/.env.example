# 阿里云百炼（通义千问）API Key —— 必填，缺失时相关接口会明确报错
# 获取步骤：登录 https://bailian.console.aliyun.com/ -> API-KEY -> 创建
DASHSCOPE_API_KEY=YOUR_DASHSCOPE_API_KEY_HERE

# OpenAI 兼容端点（一般无需修改）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称，可切换 qwen-max / qwen-turbo / qwen3.7-plus 等
LLM_MODEL=glm-5.1
LLM_TIMEOUT=60
LLM_TEMPERATURE=0.2

# 数据库（默认 SQLite 本地文件）
DATABASE_URL=sqlite:///./internscout.db

# 允许跨域来源，多个用逗号分隔，* 表示全部
CORS_ORIGINS=*
